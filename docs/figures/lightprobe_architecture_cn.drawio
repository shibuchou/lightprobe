e" value="本地状态&#xa;/tmp/lightprobe_state.bin&#xa;记录 probe 元数据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#111827;fontSize=14;strokeWidth=2;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="300" y="410" width="190" height="92" as="geometry"/></mxCell> <mxCell id="controller" value="controller&#xa;ptrace 暂停线程&#xa;解析 maps / ELF&#xa;远程读写 / mmap / munmap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontColor=#111827;fontSize=14;strokeWidth=2;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="590" y="160" width="230" height="145" as="geometry"/></mxCell> <mxCell id="injector" value="injector&#xa;计算 patch 长度&#xa;生成 trampoline&#xa;生成 entry / ret stub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontColor=#111827;fontSize=14;strokeWidth=2;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="590" y="370" width="230" height="145" as="geometry"/></mxCell> <mxCell id="target" value="目标进程&#xa;libc 函数入口被 patch&#xa;getpid / malloc / strlen / write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#111827;fontSize=14;strokeWidth=2;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="930" y="150" width="250" height="130" as="geometry"/></mxCell> <mxCell id="runtime" value="remote runtime&#xa;config：开关与地址配置&#xa;event buffer：4096 条 ring buffer&#xa;shadow stack：按 tid 保存返回地址&#xa;entry / ret stub：采集参数、返回值和耗时" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#111827;fontSize=14;strokeWidth=2;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="930" y="350" width="290" height="175" as="geometry"/></mxCell> <mxCell id="events" value="events 输出&#xa;普通文本 / CSV&#xa;entry 与 return 成对事件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=14;strokeWidth=2;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="13